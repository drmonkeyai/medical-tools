function SimpleList({
  items,
  emptyText,
}: {
  items: string[];
  emptyText: string;
}) {
  if (items.length === 0) {
    return <EmptyState text={emptyText} />;
  }

  return (
    <div style={{ display: "grid", gap: 10 }}>
      {items.map((item, index) => (
        <div
          key={`${index}-${item}`}
          style={{
            border: "1px solid #e2e8f0",
            borderRadius: 12,
            padding: 14,
            background: "#ffffff",
            color: "#0f172a",
            lineHeight: 1.55,
            whiteSpace: "pre-wrap",
          }}
        >
          {item}
        </div>
      ))}
    </div>
  );
}

